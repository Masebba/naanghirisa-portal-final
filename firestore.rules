rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role() { return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? userDoc().data.role : null; }
    function isAdmin() { return role() in ['SUPER_ADMIN', 'MID_ADMIN', 'STAFF_ADMIN']; }
    function isSelf(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /site/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || isSelf(userId));
      allow create: if isAdmin() || isSelf(userId);
      allow update: if isAdmin() || isSelf(userId);
      allow delete: if isAdmin();
    }

    match /programs/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /campaigns/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /news/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /leaders/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /taskLibrary/{docId} { allow read, write: if isAdmin(); }
    match /notifications/{docId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /donations/{docId} { allow read: if isAdmin() || isSelf(resource.data.userId); allow create: if true; allow update, delete: if isAdmin(); }
    match /expenditures/{docId} { allow read: if isAdmin() || resource.data.status == 'Approved'; allow write: if isAdmin(); }
    match /otherIncome/{docId} { allow read, write: if isAdmin(); }
    match /volunteers/{docId} { allow read: if isAdmin() || isSelf(resource.data.userId); allow create: if true; allow update, delete: if isAdmin(); }
    match /feedback/{docId} { allow read, write: if isSignedIn() || true; }
    match /{document=**} { allow read, write: if false; }
  }
}
